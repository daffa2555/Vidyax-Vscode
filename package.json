{
  "name": "vidyax",
  "displayName": "Vidyax Language",
  "description": "Syntax highlighting and editing support for the Vidyax programming language (.vx)",
  "version": "1.1.0",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:vidyax"
  ],
  "publisher": "nadev",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.63.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "vidyax",
    "vx",
    "programming language",
    "ai-first",
    "interpreter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daffa2555/Vidyax-Vscode.git"
  },
  "bugs": {
    "url": "https://github.com/daffa2555/Vidyax-Vscode/issues"
  },
  "homepage": "https://github.com/Vidyax-Lang/Vidyax",
  "galleryBanner": {
    "color": "#1A1630",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "vidyax",
        "aliases": [
          "Vidyax",
          "vidyax"
        ],
        "extensions": [
          ".vx",
          ".vax"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/vidyax-file-light.svg",
          "dark": "./icons/vidyax-file-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "vidyax",
        "scopeName": "source.vidyax",
        "path": "./syntaxes/vidyax.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vidyax.run",
        "title": "Run Vidyax Code",
        "icon": "$(play)"
      }
    ],
    "configuration": {
      "title": "Vidyax",
      "properties": {
        "vidyax.path": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the 'vidyax' executable. Leave empty to auto-detect (~/.local/bin/vidyax, then PATH). Set this if live errors don't appear."
        }
      }
    },
    "menus": {
      "editor/title/run": [
        {
          "command": "vidyax.run",
          "when": "resourceLangId == vidyax",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "vidyax.run",
          "when": "resourceLangId == vidyax"
        }
      ]
    },
    "keybindings": [
      {
        "command": "vidyax.run",
        "key": "ctrl+alt+r",
        "when": "editorLangId == vidyax"
      }
    ]
  }
}
